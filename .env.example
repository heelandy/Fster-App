# ─────────────────────────────────────────────────────────────
# Foster Care Home Management System — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foster_care?schema=public"

# NextAuth — generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Key for encrypting sensitive fields & uploaded files at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32   — MUST be kept stable and backed up;
# losing it makes all encrypted data permanently unrecoverable.
ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"

# Public base URL of the app (used by Stripe redirects, document links)
APP_URL="http://localhost:3000"

# ── Stripe ──────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys (use TEST keys in dev)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret from `stripe listen` or the Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Price IDs for each paid plan (create products/prices in Stripe first)
STRIPE_PRICE_FAMILY_MONTHLY="price_xxx"
STRIPE_PRICE_FAMILY_ANNUAL="price_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_PRO_ANNUAL="price_xxx"
STRIPE_PRICE_AGENCY_MONTHLY="price_xxx"
STRIPE_PRICE_AGENCY_ANNUAL="price_xxx"

# ── File storage ────────────────────────────────────────────
# Local secure storage directory (kept outside /public, served via guarded route).
# In production, point this at a private bucket or encrypted volume.
FILE_STORAGE_DIR="./storage/uploads"
# Max upload size in bytes (default 10 MB)
MAX_UPLOAD_BYTES="10485760"

# ── Security ────────────────────────────────────────────────
# Comma-separated list of allowed origins for CSRF/Origin checks
ALLOWED_ORIGINS="http://localhost:3000"

# ── Email (transactional) ───────────────────────────────────
# Password resets, household invites and appointment reminders are emailed.
# Uses the Resend HTTP API (https://resend.com). If RESEND_API_KEY is left blank,
# the app runs in "dev email" mode: messages are written to the server log
# (so reset/invite links are still usable locally) but not actually sent.
RESEND_API_KEY=""
EMAIL_FROM="Foster Care HMS <onboarding@resend.dev>"

# ── Reminder cron ───────────────────────────────────────────
# Shared secret guarding POST/GET /api/cron/reminders. Call it on a schedule
# (Vercel Cron, a Windows Task, cron-job.org…) with header:
#   Authorization: Bearer <CRON_SECRET>
# Leave blank to disable the endpoint (returns 503). Generate with: openssl rand -hex 32
CRON_SECRET=""

# ── File storage backend ────────────────────────────────────
# "local" (default): private disk dir (FILE_STORAGE_DIR above). Fine for a single
# persistent-disk host. "s3": S3-compatible object storage (AWS S3 / Cloudflare R2)
# — REQUIRED on serverless/multi-instance hosts where the local disk is ephemeral.
STORAGE_DRIVER="local"
STORAGE_S3_ENDPOINT=""          # e.g. https://<account>.r2.cloudflarestorage.com  (or https://s3.<region>.amazonaws.com)
STORAGE_S3_REGION="auto"        # "auto" for R2; the bucket region for AWS
STORAGE_S3_BUCKET=""
STORAGE_S3_ACCESS_KEY_ID=""
STORAGE_S3_SECRET_ACCESS_KEY=""

# ── Distributed rate limiting (optional) ────────────────────
# Upstash Redis (REST) adds cross-instance rate limiting on credential endpoints
# (login, registration, password reset, email verification). Unset = per-instance
# in-memory limiting only (fine for a single instance).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── Error reporting (optional) ──────────────────────────────
# When set, unhandled server errors are POSTed here as JSON (Slack/Discord webhook,
# a Sentry relay, or your own collector). Unset = console logging only.
ERROR_WEBHOOK_URL=""
