# ─────────────────────────────────────────────────────────────
# Foster Care Home Management System — environment variables
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/foster_care?schema=public"

# NextAuth — generate a strong secret with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Key for encrypting sensitive fields & uploaded files at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32   — MUST be kept stable and backed up;
# losing it makes all encrypted data permanently unrecoverable.
ENCRYPTION_KEY="replace-with-a-long-random-encryption-key"

# Public base URL of the app (used by Stripe redirects, document links)
APP_URL="http://localhost:3000"

# ── Stripe ──────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys (use TEST keys in dev)
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_PUBLISHABLE_KEY="pk_test_xxx"
# Webhook signing secret from `stripe listen` or the Stripe dashboard
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# Stripe Price IDs for each paid plan (create products/prices in Stripe first)
STRIPE_PRICE_FAMILY_MONTHLY="price_xxx"
STRIPE_PRICE_FAMILY_ANNUAL="price_xxx"
STRIPE_PRICE_PRO_MONTHLY="price_xxx"
STRIPE_PRICE_PRO_ANNUAL="price_xxx"
STRIPE_PRICE_AGENCY_MONTHLY="price_xxx"
STRIPE_PRICE_AGENCY_ANNUAL="price_xxx"

# ── File storage ────────────────────────────────────────────
# Local secure storage directory (kept outside /public, served via guarded route).
# In production, point this at a private bucket or encrypted volume.
FILE_STORAGE_DIR="./storage/uploads"
# Max upload size in bytes (default 10 MB)
MAX_UPLOAD_BYTES="10485760"

# ── Security ────────────────────────────────────────────────
# Comma-separated list of allowed origins for CSRF/Origin checks
ALLOWED_ORIGINS="http://localhost:3000"
