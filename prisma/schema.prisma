// Foster Care Home Management System — database schema
// PostgreSQL + Prisma. All tenant data is scoped to a Household.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───────────────────────────── Enums ─────────────────────────────

enum GlobalRole {
  USER
  ADMIN
}

// Platform-staff roles for the admin console (granular permissions in lib/admin.ts).
enum AdminRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SUPPORT
  MODERATOR
  FINANCE_ADMIN
  READ_ONLY
}

enum HouseholdRole {
  FOSTER_PARENT // full management of the household
  CO_PARENT // household member, can be permission-limited
  BABYSITTER // respite caregiver, limited care instructions only
}

enum PlanTier {
  FREE
  FAMILY
  PRO
  AGENCY
}

enum BillingInterval {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  GRACE // failed payment, inside grace period — access retained
  CANCELED
  INCOMPLETE
  UNPAID // grace expired — paid access removed
}

enum PlacementStatus {
  PENDING
  ACTIVE
  RESPITE
  TRIAL_HOME_VISIT
  REUNIFIED
  ADOPTED
  ENDED
}

// A foster parent's answer to a child the agency assigned to their home.
enum PlacementResponse {
  PENDING // awaiting the foster parent's decision
  ACCEPTED // "Y" — foster parent accepted the placement
  DECLINED // "N" — foster parent declined the placement
}

// Agency oversight status of a foster home (does NOT gate the foster parent's own
// app access — it is the agency's approval/suspension record for the home).
enum FosterStatus {
  PENDING // application under review
  APPROVED // approved to foster
  SUSPENDED // temporarily suspended by the agency
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
}

// Incident lifecycle: foster parent reports → case worker reviews → agency
// escalates / resolves / closes.
enum IncidentStatus {
  REPORTED
  UNDER_REVIEW
  ESCALATED
  RESOLVED
  CLOSED
}

// A case-worker visit can be scheduled ahead of time, then marked completed.
enum VisitStatus {
  SCHEDULED
  COMPLETED
}

// Case goal lifecycle (agency sets goals for a placement; foster parent follows).
enum GoalStatus {
  OPEN
  IN_PROGRESS
  MET
  CANCELLED
}

enum AppointmentType {
  DOCTOR
  THERAPY
  DENTAL
  COURT
  SCHOOL_MEETING
  CASEWORKER_VISIT
  HOME_INSPECTION
  LICENSING_DEADLINE
  OTHER
}

enum ContactRole {
  CASEWORKER
  LICENSING_WORKER
  GAL
  ATTORNEY
  THERAPIST
  DOCTOR
  DENTIST
  TEACHER
  SCHOOL_COUNSELOR
  BIOLOGICAL_FAMILY
  EMERGENCY
  OTHER
}

enum ExpenseCategory {
  CLOTHING
  SCHOOL_SUPPLIES
  FOOD
  HYGIENE
  ACTIVITIES
  TRANSPORTATION
  MEDICAL
  CHILDCARE
  ROOM_SETUP
  OTHER
}

enum DocumentCategory {
  PLACEMENT
  MEDICAL
  SCHOOL
  COURT
  LICENSING
  RECEIPT
  CASE_NOTE
  OTHER
}

enum LicensingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
  DUE_SOON
  EXPIRED
}

enum RoutineType {
  MORNING
  AFTER_SCHOOL
  BEDTIME
  VISIT_DAY
  SCHOOL_DAY
  INTAKE
  HOME_INSPECTION
  MEDICATION
  CUSTOM
}

// Court hearing categories (Phase 15 — Court Management).
enum CourtHearingType {
  PRELIMINARY
  ADJUDICATION
  DISPOSITION
  REVIEW
  PERMANENCY
  TERMINATION
  ADOPTION
  STATUS_CONFERENCE
  OTHER
}

// Education record categories (Phase 16 — Education Management).
enum EducationRecordType {
  ENROLLMENT
  IEP
  MEETING
  GRADE_REPORT
  ATTENDANCE
  CONCERN
  ACHIEVEMENT
  OTHER
}

enum TicketStatus {
  OPEN // awaiting staff
  PENDING // awaiting user reply
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

// ───────────────────────────── Auth / Tenancy ─────────────────────────────

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  passwordHash  String
  globalRole    GlobalRole @default(USER)
  adminRole     AdminRole? // null unless this user is admin staff
  isActive      Boolean    @default(true)
  isBanned      Boolean    @default(false)
  internalNote  String? // admin-only note about the account
  failedLogins  Int        @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  // Two-factor (TOTP). Secret is encrypted at rest (see lib/prisma.ts middleware).
  twoFactorSecret    String?
  twoFactorEnabledAt DateTime?
  twoFactorBackupCodes Json? // array of bcrypt-hashed single-use recovery codes
  // Bumped to invalidate every existing session (password reset / forced logout).
  tokenVersion  Int        @default(0)
  emailVerifiedAt DateTime? // set when the user confirms their email address
  deletedAt     DateTime? // admin soft-delete: blocks login, record retained for recovery
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  ownedHouseholds Household[]        @relation("HouseholdOwner")
  memberships     HouseholdMember[]
  adminAuditLogs  AdminAuditLog[]    @relation("AdminActor")
  securityLogs    SecurityAuditLog[] @relation("SecurityActor")
  passwordResets  PasswordResetToken[]
  emailVerifications EmailVerificationToken[]
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]   @relation("SupportAuthor")
  sessions        UserSession[]
  agencyMemberships AgencyMember[]

  @@index([email])
}

/// One row per signed-in device/browser, enabling a per-device session list and
/// selective revocation. The JWT carries this row's id (sid); requireUser rejects
/// a token whose session row is missing or revoked. Complements the global
/// User.tokenVersion ("sign out everywhere").
model UserSession {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userAgent  String?
  ip         String?
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  revokedAt  DateTime?

  @@index([userId])
}

model Household {
  id              String   @id @default(cuid())
  name            String
  ownerId         String
  owner           User     @relation("HouseholdOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  // A foster home may be overseen by an agency (multi-agency platform). The home
  // owner still owns/manages it; the agency gets scoped oversight (see lib/agency).
  agencyId        String?
  agency          Agency?  @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  // Agency's approval/suspension record for this home (oversight metadata only).
  fosterStatus    FosterStatus @default(APPROVED)
  stripeCustomerId String? @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members      HouseholdMember[]
  invites      HouseholdInvite[]
  children     ChildProfile[]
  appointments Appointment[]
  documents    Document[]
  careLogs     DailyCareLog[]
  medications  Medication[]
  expenses     Expense[]
  contacts     Contact[]
  routines     Routine[]
  checklists   Checklist[]
  licensing    LicensingRequirement[]
  trainingHours TrainingHour[]
  visits       Visit[]
  incidents    Incident[]
  goals        Goal[]
  messages     Message[]
  behaviorLogs BehaviorLog[]
  inventory    InventoryItem[]
  communications CommunicationLog[]
  journalEntries JournalEntry[]
  courtHearings   CourtHearing[]
  educationRecords EducationRecord[]
  immunizations   Immunization[]
  subscription Subscription?

  @@index([ownerId])
  @@index([agencyId])
}

/// Multi-agency platform: an organization that oversees multiple foster homes and
/// employs staff (agency admins, case workers). Oversight is scoped to the
/// agency's own homes — staff never see homes outside their agency.
model Agency {
  id         String         @id @default(cuid())
  name       String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  members    AgencyMember[]
  households Household[]
  announcements Announcement[]
}

enum AgencyRole {
  AGENCY_ADMIN // manage staff, homes, placements; full oversight
  CASE_WORKER // view homes/children, manage placements + case notes
  AGENCY_VIEWER // read-only oversight
}

model AgencyMember {
  id        String     @id @default(cuid())
  agencyId  String
  agency    Agency     @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      AgencyRole @default(CASE_WORKER)
  createdAt DateTime   @default(now())

  @@unique([agencyId, userId])
  @@index([userId])
}

model HouseholdMember {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        HouseholdRole @default(CO_PARENT)
  // Granular permission flags (JSON) layered on top of the role for fine control.
  permissions Json          @default("{}")
  invitedAt   DateTime      @default(now())
  acceptedAt  DateTime?

  @@unique([householdId, userId])
  @@index([userId])
  @@index([householdId])
}

// ───────────────────────────── Children ─────────────────────────────

model ChildProfile {
  id              String          @id @default(cuid())
  householdId     String
  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  firstName       String
  preferredName   String?
  lastName        String?
  dateOfBirth     DateTime?
  placementStatus PlacementStatus @default(ACTIVE)
  // Sensitive fields — access restricted by RBAC; encrypt at rest in production.
  caseNumber      String?
  caseworkerName  String?
  school          String?
  doctorName      String?
  allergies       String?
  importantNotes  String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  placements   Placement[]
  appointments Appointment[]
  documents    Document[]
  careLogs     DailyCareLog[]
  medications  Medication[]
  expenses     Expense[]
  contacts     Contact[]
  routines     Routine[]
  checklists   Checklist[]
  visits       Visit[]
  behaviorLogs BehaviorLog[]
  inventory    InventoryItem[]
  communications CommunicationLog[]
  journalEntries JournalEntry[]
  courtHearings   CourtHearing[]
  educationRecords EducationRecord[]
  immunizations   Immunization[]

  @@index([householdId])
}

model Placement {
  id            String          @id @default(cuid())
  childId       String
  child         ChildProfile    @relation(fields: [childId], references: [id], onDelete: Cascade)
  status        PlacementStatus @default(ACTIVE)
  placementDate DateTime
  endDate       DateTime?
  agency        String?
  notes         String?
  // Agency placements land with the foster parent for acceptance: PENDING until
  // they accept (→ TRIAL_HOME_VISIT) or decline (→ ENDED). The Y/N is recorded here.
  parentResponse PlacementResponse @default(PENDING)
  respondedAt    DateTime?
  createdById   String? // agency staff who created the placement (staff metrics)
  createdAt     DateTime        @default(now())

  @@index([childId])
}

/// A recorded visit to a foster home — a case-worker home visit, court date,
/// school meeting, etc. Logged by agency staff; visible to the foster parent.
model Visit {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  agencyId    String?
  visitType   String? // Home visit, Court, School, Medical, Other
  visitDate   DateTime
  status      VisitStatus @default(COMPLETED) // future-dated visits are SCHEDULED
  summary     String?
  createdById String?
  createdAt   DateTime      @default(now())

  @@index([householdId, visitDate])
}

/// An incident a foster parent reports about a placement. The agency's case
/// worker reviews it and escalates / resolves / closes it (incident workflow).
model Incident {
  id           String           @id @default(cuid())
  householdId  String
  household    Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId      String?
  agencyId     String?
  reportedById String?
  title        String
  description  String?
  severity     IncidentSeverity @default(LOW)
  status       IncidentStatus   @default(REPORTED)
  resolution   String? // case worker's review / resolution note
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([householdId, createdAt])
  @@index([agencyId, status])
}

/// An announcement an agency broadcasts to its foster homes (shown on the foster
/// parent's dashboard). Agency → its homes, one-way.
model Announcement {
  id          String   @id @default(cuid())
  agencyId    String
  agency      Agency   @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  title       String
  body        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([agencyId, createdAt])
}

/// A case goal the agency sets for a placement (e.g. "reunification", "attend
/// therapy weekly"). Foster parent can view; case worker manages.
model Goal {
  id          String     @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  agencyId    String?
  title       String
  description String?
  status      GoalStatus @default(OPEN)
  targetDate  DateTime?
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([householdId, status])
}

/// A secure message between an agency and one of its foster homes. `fromAgency`
/// marks the direction; both sides read the same household-scoped thread.
model Message {
  id          String    @id @default(cuid())
  householdId String
  household   Household  @relation(fields: [householdId], references: [id], onDelete: Cascade)
  agencyId    String?
  senderId    String?
  fromAgency  Boolean   @default(false)
  body        String
  createdAt   DateTime  @default(now())

  @@index([householdId, createdAt])
}

/// Trauma-informed behaviour entry (TBRI-style) — richer than a daily care log.
model BehaviorLog {
  id           String       @id @default(cuid())
  householdId  String
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId      String
  child        ChildProfile  @relation(fields: [childId], references: [id], onDelete: Cascade)
  logDate      DateTime
  trigger      String?
  emotion      String?
  coping       String?
  intervention String?
  strength     String?
  notes        String?
  authorId     String?
  createdAt    DateTime      @default(now())

  @@index([householdId, logDate])
  @@index([childId, logDate])
}

/// Foster-closet / inventory item (clothing & supplies) with restock flag.
model InventoryItem {
  id          String        @id @default(cuid())
  householdId String
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile?  @relation(fields: [childId], references: [id], onDelete: SetNull)
  name        String
  category    String?
  size        String?
  quantity    Int?
  needed      Boolean       @default(false) // flagged as needing restock
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([householdId])
}

/// Communication-hub log entry — a call / email / meeting with a contact.
model CommunicationLog {
  id          String        @id @default(cuid())
  householdId String
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile?  @relation(fields: [childId], references: [id], onDelete: SetNull)
  contactId   String? // optional reference to a Contact (no FK; contacts may change)
  logDate     DateTime
  method      String? // Call, Email, Meeting, Text, Other
  summary     String
  authorId    String?
  createdAt   DateTime      @default(now())

  @@index([householdId, logDate])
}

/// Child story & success journal entry → keepsake memory book at adoption.
model JournalEntry {
  id          String        @id @default(cuid())
  householdId String
  household   Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String
  child       ChildProfile   @relation(fields: [childId], references: [id], onDelete: Cascade)
  entryDate   DateTime
  title       String?
  body        String
  authorId    String?
  createdAt   DateTime      @default(now())

  @@index([householdId, entryDate])
  @@index([childId, entryDate])
}

/// A court hearing for a child's case (Phase 15 — Court Management). Permanency,
/// review, adoption, etc., with judge / attorney / outcome and the next date.
model CourtHearing {
  id              String           @id @default(cuid())
  householdId     String
  household       Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId         String?
  child           ChildProfile?    @relation(fields: [childId], references: [id], onDelete: SetNull)
  type            CourtHearingType @default(OTHER)
  hearingDate     DateTime
  location        String?
  judge           String?
  attorney        String?
  outcome         String? // ruling / orders made at the hearing
  nextHearingDate DateTime?
  notes           String?
  createdById     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([householdId, hearingDate])
  @@index([childId])
}

/// A school / education record for a child (Phase 16 — Education Management):
/// enrollment, IEP, grade report, attendance, meeting, concern.
model EducationRecord {
  id          String              @id @default(cuid())
  householdId String
  household   Household           @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String
  child       ChildProfile        @relation(fields: [childId], references: [id], onDelete: Cascade)
  type        EducationRecordType @default(OTHER)
  recordDate  DateTime
  school      String?
  grade       String? // grade level or grade/score, free-form
  hasIep      Boolean             @default(false)
  notes       String?
  authorId    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([householdId, recordDate])
  @@index([childId])
}

/// A vaccination / immunization record for a child (Phase 17 — Medical Management),
/// complementing Medication. Tracks the dose given and an optional next-dose date.
model Immunization {
  id           String        @id @default(cuid())
  householdId  String
  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId      String
  child        ChildProfile  @relation(fields: [childId], references: [id], onDelete: Cascade)
  vaccine      String
  dateGiven    DateTime
  nextDoseDate DateTime?
  provider     String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([householdId])
  @@index([childId])
}

// ───────────────────────────── Appointments ─────────────────────────────

model Appointment {
  id          String          @id @default(cuid())
  householdId String
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile?   @relation(fields: [childId], references: [id], onDelete: SetNull)
  title       String
  type        AppointmentType @default(OTHER)
  location    String?
  startsAt    DateTime
  endsAt      DateTime?
  reminderAt  DateTime?
  reminderSent Boolean        @default(false)
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([householdId, startsAt])
  @@index([childId])
}

// ───────────────────────────── Documents ─────────────────────────────

model Document {
  id           String           @id @default(cuid())
  householdId  String
  household    Household        @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId      String?
  child        ChildProfile?    @relation(fields: [childId], references: [id], onDelete: SetNull)
  category     DocumentCategory @default(OTHER)
  title        String
  // Storage key is an opaque path inside the private storage dir — never a public URL.
  storageKey   String
  originalName String
  mimeType     String
  sizeBytes    Int
  uploadedById String
  createdAt    DateTime         @default(now())

  @@index([householdId])
  @@index([childId])
}

// ───────────────────────────── Daily care logs ─────────────────────────────

model DailyCareLog {
  id              String       @id @default(cuid())
  householdId     String
  household       Household    @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId         String
  child           ChildProfile @relation(fields: [childId], references: [id], onDelete: Cascade)
  logDate         DateTime
  meals           String?
  sleep           String?
  behavior        String?
  mood            String?
  schoolUpdate    String?
  visits          String?
  medicalConcerns String?
  incidents       String?
  milestones      String?
  generalNotes    String?
  authorId        String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([householdId, logDate])
  @@index([childId, logDate])
}

// ───────────────────────────── Medications ─────────────────────────────

model Medication {
  id              String          @id @default(cuid())
  householdId     String
  household       Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId         String
  child           ChildProfile    @relation(fields: [childId], references: [id], onDelete: Cascade)
  name            String
  dosage          String?
  schedule        String? // e.g. "Twice daily, 8am & 8pm"
  startDate       DateTime?
  endDate         DateTime?
  prescribingDoctor String?
  notes           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  logs MedicationLog[]

  @@index([householdId])
  @@index([childId])
}

model MedicationLog {
  id           String     @id @default(cuid())
  medicationId String
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)
  givenAt      DateTime
  status       String     @default("GIVEN") // GIVEN | MISSED | REFUSED
  givenById    String?
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([medicationId, givenAt])
}

// ───────────────────────────── Expenses ─────────────────────────────

model Expense {
  id          String          @id @default(cuid())
  householdId String
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile?   @relation(fields: [childId], references: [id], onDelete: SetNull)
  category    ExpenseCategory @default(OTHER)
  description String
  amountCents Int
  spentAt     DateTime
  createdById String
  createdAt   DateTime        @default(now())

  receipts Receipt[]

  @@index([householdId, spentAt])
}

model Receipt {
  id           String   @id @default(cuid())
  expenseId    String
  expense      Expense  @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  storageKey   String
  originalName String
  mimeType     String
  sizeBytes    Int
  createdAt    DateTime @default(now())

  @@index([expenseId])
}

// ───────────────────────────── Contacts ─────────────────────────────

model Contact {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  name        String
  role        ContactRole   @default(OTHER)
  phone       String?
  email       String?
  agency      String?
  notes       String?
  // Legal/court-linked contacts are hidden from babysitter caregivers.
  isLegal     Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([householdId])
}

// ───────────────────────────── Routines & checklists ─────────────────────────────

model Routine {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  name        String
  type        RoutineType   @default(CUSTOM)
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  tasks RoutineTask[]

  @@index([householdId])
  @@index([childId])
}

model RoutineTask {
  id        String   @id @default(cuid())
  routineId String
  routine   Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)
  title     String
  order     Int      @default(0)
  isDone    Boolean  @default(false)

  @@index([routineId])
}

model Checklist {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  childId     String?
  child       ChildProfile? @relation(fields: [childId], references: [id], onDelete: SetNull)
  name        String
  type        RoutineType   @default(CUSTOM)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items ChecklistItem[]

  @@index([householdId])
  @@index([childId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  title       String
  order       Int       @default(0)
  isDone      Boolean   @default(false)
  doneAt      DateTime?

  @@index([checklistId])
}

// ───────────────────────────── Licensing & compliance ─────────────────────────────

model LicensingRequirement {
  id          String          @id @default(cuid())
  householdId String
  household   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  name        String // e.g. "Fire inspection", "CPR/First Aid"
  category    String? // Training, Background, HomeStudy, Medical, Renewal, Document...
  status      LicensingStatus @default(NOT_STARTED)
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([householdId, dueDate])
}

model TrainingHour {
  id          String    @id @default(cuid())
  householdId String
  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  title       String
  hours       Float
  completedAt DateTime
  provider    String?
  // Phase 14 — Training Management: certificate category and renewal/expiry date
  // so CPR / First Aid / Trauma-Informed certifications can be tracked + renewed.
  category    String? // Orientation, Annual, CPR, First Aid, Trauma-Informed, Behavioral, Other
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([householdId])
}

// ───────────────────────────── Billing ─────────────────────────────

model Plan {
  id              String          @id @default(cuid())
  tier            PlanTier        @unique
  name            String
  description     String?
  priceCentsMonthly Int           @default(0)
  priceCentsAnnual  Int           @default(0)
  stripePriceMonthly String?
  stripePriceAnnual  String?
  // Feature flags / limits encoded as JSON (see lib/plans.ts for the source of truth).
  features        Json            @default("{}")
  isActive        Boolean         @default(true)
}

model Subscription {
  id                   String             @id @default(cuid())
  householdId          String             @unique
  household            Household          @relation(fields: [householdId], references: [id], onDelete: Cascade)
  tier                 PlanTier           @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  interval             BillingInterval    @default(MONTHLY)
  stripeSubscriptionId String?            @unique
  stripeCustomerId     String?
  currentPeriodEnd     DateTime?
  graceUntil           DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  trialEndsAt          DateTime?
  // Admin-granted plan (comped / grant / scholarship / government-funded). When
  // true, the plan is set manually and the Stripe reconcile leaves it untouched.
  comped               Boolean            @default(false)
  compNote             String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  payments Payment[]
  invoices Invoice[]
}

model Payment {
  id              String        @id @default(cuid())
  subscriptionId  String
  subscription    Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripePaymentId String?       @unique
  amountCents     Int
  currency        String        @default("usd")
  status          String // succeeded | failed | refunded
  createdAt       DateTime      @default(now())

  @@index([subscriptionId])
}

model Invoice {
  id              String       @id @default(cuid())
  subscriptionId  String
  subscription    Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  stripeInvoiceId String?      @unique
  amountDueCents  Int
  amountPaidCents Int          @default(0)
  status          String // draft | open | paid | void | uncollectible
  hostedInvoiceUrl String?
  pdfUrl          String?
  periodStart     DateTime?
  periodEnd       DateTime?
  createdAt       DateTime     @default(now())

  @@index([subscriptionId])
}

// ───────────────────────────── Audit logs ─────────────────────────────

// System settings managed from the admin console (maintenance mode, signup
// toggle, feature flags…). Key/value so new settings need no migration.
model Setting {
  key       String   @id
  value     String
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// Admin-facing notifications generated on important events (payment failed,
// new signup, etc.).
model Notification {
  id        String   @id @default(cuid())
  type      String
  message   String
  level     String   @default("info") // info | warning | critical
  isRead    Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([isRead, createdAt])
}

// Records every Stripe webhook event id we have processed, so retried or
// replayed deliveries are acknowledged but not processed twice.
model ProcessedWebhookEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("AdminActor", fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  targetType String?
  targetId   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([createdAt])
}

model SecurityAuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation("SecurityActor", fields: [actorId], references: [id], onDelete: SetNull)
  event     String // LOGIN_SUCCESS, LOGIN_FAILED, ACCESS_DENIED, RATE_LIMITED, FILE_DOWNLOAD, etc.
  ip        String?
  userAgent String?
  path      String?
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())

  @@index([event, createdAt])
  @@index([actorId])
}

// ───────────────────────────── Account recovery ─────────────────────────────

// Single-use password-reset tokens. Only a SHA-256 hash of the token is stored;
// the raw token is emailed and never persisted.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// Single-use email-verification tokens (hash stored, raw emailed).
model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ───────────────────────────── Support tickets ─────────────────────────────

model SupportTicket {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject       String
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(NORMAL)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  lastMessageAt DateTime       @default(now())

  messages SupportMessage[]

  @@index([userId])
  @@index([status, lastMessageAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String?
  author    User?         @relation("SupportAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  fromStaff Boolean       @default(false)
  body      String
  createdAt DateTime      @default(now())

  @@index([ticketId, createdAt])
}

// ───────────────────────────── Household invites ─────────────────────────────

// Email-based invitation to join a household. Only a hash of the token is stored;
// the raw token travels in the emailed accept link.
model HouseholdInvite {
  id          String        @id @default(cuid())
  householdId String
  household   Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  email       String
  role        HouseholdRole @default(CO_PARENT)
  permissions Json          @default("{}")
  tokenHash   String        @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([householdId])
  @@index([email])
}
